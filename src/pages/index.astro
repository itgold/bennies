---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import StatBand from '../components/StatBand.astro';
import HowWeHelp from '../components/HowWeHelp.astro';
import ImpactMetrics from '../components/ImpactMetrics.astro';
import PeopleSection from '../components/PeopleSection.astro';
import TrustPills from '../components/TrustPills.astro';
import FaqSection from '../components/FaqSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<BaseLayout>
  <Header />
  <main id="main">
    <div class="container">
      <Hero />
    </div>

    <StatBand />

    <div class="container">
      <HowWeHelp />
    </div>

    <div class="container">
      <ImpactMetrics />
    </div>

    <div class="container">
      <PeopleSection />
    </div>

    <div class="container">
      <TrustPills />
    </div>

    <div class="container">
      <FaqSection />
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  main { position: relative; }
  main > .container,
  main > section { position: relative; z-index: 1; }
</style>
