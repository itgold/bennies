---
interface Props {
  name: string;
  labelledBy: string;
  defaultValue?: string;
  options?: string[];
}
const { name, labelledBy, defaultValue = 'No', options = ['Yes', 'No'] } = Astro.props;
---
<div class="pill-group" role="radiogroup" aria-labelledby={labelledBy} data-name={name}>
  {options.map((opt) => (
    <label class={`pill ${opt === defaultValue ? 'is-active' : ''}`}>
      <input
        type="radio"
        name={name}
        value={opt}
        checked={opt === defaultValue}
        class="sr-only"
      />
      <span>{opt}</span>
    </label>
  ))}
</div>

<style>
  .pill-group {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 64px;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    border: 2px solid var(--line-strong);
    background: var(--surface);
    color: var(--ink-2);
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    user-select: none;
    min-height: 44px;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .pill:hover { border-color: var(--color-blue); color: var(--ink); }
  .pill:focus-within { outline: var(--focus-ring); outline-offset: var(--focus-ring-offset); }
  .pill.is-active {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>('.pill-group').forEach((group) => {
    group.querySelectorAll<HTMLLabelElement>('.pill').forEach((label) => {
      label.addEventListener('click', () => {
        group.querySelectorAll('.pill').forEach((p) => p.classList.remove('is-active'));
        label.classList.add('is-active');
      });
    });
  });
</script>
