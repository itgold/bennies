---
import Logo from './Logo.astro';
import ProgressIndicator from './ProgressIndicator.astro';

interface Props {
  step?: number;
  totalSteps?: number;
}
const { step, totalSteps } = Astro.props;
const showProgress = typeof step === 'number' && typeof totalSteps === 'number';

const languages = [
  { code: 'EN', name: 'English',     native: 'English' },
  { code: 'RU', name: 'Russian',     native: 'Русский' },
  { code: 'VI', name: 'Vietnamese',  native: 'Tiếng Việt' },
  { code: 'HI', name: 'Hindi',       native: 'हिन्दी' },
];
---
<header class="site-header">
  <div class="container header-inner">
    <Logo />

    <nav class="site-nav" aria-label="Primary">
      <a href="/onboarding">Check eligibility</a>
      <a href="/appeal">Appeal a denial</a>
      <a href="/faq">FAQ</a>
    </nav>

    {showProgress ? (
      <ProgressIndicator step={step!} totalSteps={totalSteps!} />
    ) : (
      <div class="header-tools" role="toolbar" aria-label="Accessibility and language">
        <button
          type="button"
          class="tool-btn"
          aria-label="Read this page aloud"
          data-tool="read-aloud"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true" fill="none">
            <path d="M2 6v4h2.5L8 13V3L4.5 6H2z" fill="currentColor"/>
            <path d="M11 5c1 1 1 5 0 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
          </svg>
          <span>Listen</span>
        </button>

        <label class="lang-select-wrap" aria-label="Switch language">
          <svg class="lang-globe" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true" fill="none">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M1.5 8h13M8 1.5c2 2 2 11 0 13M8 1.5c-2 2-2 11 0 13" stroke="currentColor" stroke-width="1.1" fill="none"/>
          </svg>
          <select id="lang-select" class="lang-select">
            {languages.map((l) => (
              <option value={l.code}>{l.code} · {l.native}</option>
            ))}
          </select>
          <svg class="lang-caret" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" fill="none">
            <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </label>
      </div>
    )}
  </div>
</header>

<style>
  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    position: relative;
    z-index: 40;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    padding-bottom: 20px;
    gap: 24px;
  }
  .site-nav { display: flex; gap: 28px; margin-left: auto; }
  .site-nav a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 4px 0;
    border-bottom: 1.5px solid transparent;
  }
  .site-nav a:hover { color: var(--ink); border-bottom-color: var(--blue); }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tool-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: transparent;
    border: 0;
    border-radius: var(--radius);
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    transition: color 0.12s, background 0.12s;
    letter-spacing: 0.01em;
  }
  .tool-btn:hover { color: var(--ink); background: var(--surface-2); }
  .tool-btn:focus-visible { outline-offset: 2px; }
  .tool-btn svg { color: var(--ink-3); transition: color 0.12s; }
  .tool-btn:hover svg { color: var(--blue-strong); }

  /* Small rectangular language select */
  .lang-select-wrap {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 8px 6px 10px;
    background: var(--surface-white);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    color: var(--ink);
    cursor: pointer;
    position: relative;
    transition: border-color 0.12s, background 0.12s;
  }
  .lang-select-wrap:hover { border-color: var(--blue); }
  .lang-select-wrap:focus-within {
    border-color: var(--blue);
    outline: var(--focus-ring);
    outline-offset: 2px;
  }
  .lang-globe { color: var(--ink-3); flex-shrink: 0; }
  .lang-caret { color: var(--ink-3); pointer-events: none; }
  .lang-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    padding-right: 2px;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    outline: none;
    line-height: 1.2;
  }
  .lang-select:focus { outline: none; }

  @media (max-width: 820px) {
    .site-nav { display: none; }
  }
  @media (max-width: 520px) {
    .tool-btn { padding: 6px 8px; font-size: 0.8rem; }
    .lang-list { min-width: 200px; }
  }
</style>

