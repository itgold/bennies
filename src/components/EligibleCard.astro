---
interface Props {
  amount: string;
  label?: string;
}
const { amount, label = "You're eligible for" } = Astro.props;
---
<div class="eligible-card" role="status" aria-live="polite">
  <span class="check" aria-hidden="true">✓</span>
  <div class="body">
    <span class="label">{label}</span>
    <span class="amount">{amount}</span>
    <span class="sub">in opportunities!</span>
  </div>
</div>

<style>
  .eligible-card {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--color-brand-soft);
    border: 1px solid #a7f3d0;
    padding: 12px 16px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .check {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-pill);
    background: var(--color-brand);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    flex-shrink: 0;
  }
  .body { display: flex; flex-direction: column; line-height: 1.25; }
  .label { font-size: 0.78rem; color: var(--tone-green-ink); font-weight: 600; }
  .amount { font-size: 1.35rem; font-weight: 800; color: var(--tone-green-ink); }
  .sub { font-size: 0.78rem; color: var(--tone-green-ink); }
</style>
