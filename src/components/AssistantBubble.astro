---
interface Props {
  name?: string;
  greeting: string;
  primaryLabel?: string;
  secondaryLabel?: string;
}
const {
  name = 'Bennie',
  greeting,
  primaryLabel = 'Yes, show me',
  secondaryLabel = 'Not now',
} = Astro.props;
---
<aside class="bubble" aria-label={`Message from ${name}, AI assistant`}>
  <header class="bubble-header">
    <span class="avatar" aria-hidden="true">
      <svg viewBox="0 0 40 40" width="100%" height="100%" role="img">
        <circle cx="20" cy="20" r="18" fill="#2563eb" />
        <circle cx="14" cy="18" r="2.5" fill="#fff" />
        <circle cx="26" cy="18" r="2.5" fill="#fff" />
        <path d="M14 26q6 5 12 0" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" />
      </svg>
    </span>
    <span class="name">{name}</span>
    <span class="badge">AI Opportunities Assistant</span>
  </header>
  <p class="greeting">{greeting}</p>
  <div class="actions">
    <button type="button" class="btn btn-primary btn-sm">{primaryLabel}</button>
    <button type="button" class="btn btn-ghost btn-sm">{secondaryLabel}</button>
  </div>
</aside>

<style>
  .bubble {
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 16px;
    max-width: 320px;
    border: 1px solid var(--line);
  }
  .bubble-header {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .avatar { width: 32px; height: 32px; flex-shrink: 0; }
  .name { font-weight: 700; color: var(--ink); font-size: 0.9rem; }
  .badge {
    font-size: 0.68rem;
    color: var(--color-blue-ink);
    background: var(--color-blue-soft);
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    font-weight: 600;
  }
  .greeting { margin: 0 0 12px; font-size: 0.92rem; color: var(--ink-2); }
  .actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .btn-sm {
    padding: 8px 14px;
    font-size: 0.85rem;
    min-height: 36px;
  }
</style>
