---
<div class="page-backdrop" aria-hidden="true">
  <!-- Scattered Matisse-style organic shapes. Each in its own vertical band, no overlap. -->

  <!-- 1. Kidney blob (right) -->
  <svg class="shape" style="top: 18vh; right: -10px; width: 120px; height: 90px;" viewBox="0 0 120 90" fill="none">
    <path d="M20 40 Q10 15 40 12 Q80 8 100 25 Q118 45 100 65 Q80 82 45 78 Q15 74 20 40 Z" fill="#1e40af"/>
  </svg>

  <!-- 2. Arch / rainbow (left) -->
  <svg class="shape" style="top: 52vh; left: -15px; width: 130px; height: 70px;" viewBox="0 0 130 70" fill="none">
    <path d="M10 65 Q10 10 65 10 Q120 10 120 65 L100 65 Q100 30 65 30 Q30 30 30 65 Z" fill="#0f6b3e"/>
  </svg>

  <!-- 3. Squiggle line (right) -->
  <svg class="shape" style="top: 78vh; right: -10px; width: 60px; height: 110px;" viewBox="0 0 60 110" fill="none">
    <path d="M15 5 q 30 15, 0 30 t 0 30 t 0 30 t 0 15" stroke="#9a3412" stroke-width="6" stroke-linecap="round" fill="none"/>
  </svg>

  <!-- 4. Leaf (left) -->
  <svg class="shape" style="top: 108vh; left: -5px; width: 95px; height: 130px;" viewBox="0 0 95 130" fill="none">
    <path d="M45 5 Q 5 25, 8 75 Q 12 120, 55 125 Q 85 100, 90 60 Q 88 20, 45 5 Z" fill="#1e40af" opacity="0.65"/>
    <path d="M45 20 L 60 115" stroke="#1e40af" stroke-width="1.5" opacity="0.4"/>
  </svg>

  <!-- 5. Dot cluster (right) -->
  <svg class="shape" style="top: 132vh; right: 4px; width: 80px; height: 80px;" viewBox="0 0 80 80" fill="none">
    <circle cx="15" cy="15" r="6" fill="#a16207"/>
    <circle cx="45" cy="10" r="4" fill="#a16207"/>
    <circle cx="65" cy="25" r="7" fill="#a16207"/>
    <circle cx="20" cy="40" r="5" fill="#a16207"/>
    <circle cx="50" cy="45" r="8" fill="#a16207"/>
    <circle cx="30" cy="65" r="6" fill="#a16207"/>
    <circle cx="60" cy="65" r="4" fill="#a16207"/>
  </svg>

  <!-- 6. Half-moon (left) -->
  <svg class="shape" style="top: 162vh; left: 8px; width: 110px; height: 60px;" viewBox="0 0 110 60" fill="none">
    <path d="M0 0 A 55 55 0 0 0 110 0 L 110 6 A 50 50 0 0 1 0 6 Z" fill="#0f6b3e"/>
  </svg>

  <!-- 7. Bean / pebble (right) -->
  <svg class="shape" style="top: 195vh; right: 12px; width: 100px; height: 70px;" viewBox="0 0 100 70" fill="none">
    <path d="M15 35 Q10 5 45 8 Q80 10 90 30 Q95 55 60 62 Q25 65 15 35 Z" fill="#1e40af"/>
  </svg>

  <!-- 8. S-curve squiggle (left) -->
  <svg class="shape" style="top: 225vh; left: 0px; width: 90px; height: 60px;" viewBox="0 0 90 60" fill="none">
    <path d="M5 30 q 15 -25, 30 0 t 30 0 t 20 0" stroke="#86198f" stroke-width="6" stroke-linecap="round" fill="none"/>
  </svg>

  <!-- 9. Small arch (right) -->
  <svg class="shape" style="top: 258vh; right: -8px; width: 100px; height: 55px;" viewBox="0 0 100 55" fill="none">
    <path d="M10 50 Q10 5 50 5 Q90 5 90 50 L75 50 Q75 20 50 20 Q25 20 25 50 Z" fill="#a16207"/>
  </svg>

  <!-- 10. Amoeba blob (left) -->
  <svg class="shape" style="top: 290vh; left: 4px; width: 120px; height: 95px;" viewBox="0 0 120 95" fill="none">
    <path d="M20 40 Q8 15 40 10 Q75 5 95 25 Q118 45 105 70 Q85 92 55 85 Q22 78 20 40 Z" fill="#1e40af"/>
  </svg>

  <!-- 11. Triangle drop (right) -->
  <svg class="shape" style="top: 320vh; right: 8px; width: 70px; height: 90px;" viewBox="0 0 70 90" fill="none">
    <path d="M35 5 Q 65 45, 45 80 Q 25 90, 10 65 Q 5 30, 35 5 Z" fill="#9a3412"/>
  </svg>
</div>

<style>
  .page-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .shape {
    position: absolute;
    display: block;
    opacity: 0.14;
  }
  .shape:nth-child(3n)  { opacity: 0.18; }
  .shape:nth-child(5n)  { opacity: 0.12; }

  @media (max-width: 720px) {
    .shape { opacity: 0.1; transform: scale(0.7); transform-origin: center; }
  }
</style>
