---
---
<div class="backdrop" aria-hidden="true">
  <!-- Spiral top-left -->
  <svg class="doodle d1" viewBox="0 0 60 60" fill="none">
    <path d="M30 30 m-2 0 a2 2 0 1 1 4 0 a4 4 0 1 1 -8 0 a6 6 0 1 1 12 0 a8 8 0 1 1 -16 0 a10 10 0 1 1 20 0 a12 12 0 1 1 -24 0"
      stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none" />
  </svg>

  <!-- Dollar bill top-right -->
  <svg class="doodle d2" viewBox="0 0 90 50" fill="none">
    <rect x="3" y="4" width="82" height="42" rx="4" stroke="currentColor" stroke-width="1.6" fill="none" />
    <circle cx="44" cy="25" r="10" stroke="currentColor" stroke-width="1.4" fill="none" />
    <path d="M40 22 q4 -4 8 0 q-4 4 -8 4 q4 4 8 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none" />
    <path d="M11 25 h6 M79 25 h-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
    <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.2" fill="none" />
    <circle cx="78" cy="12" r="2" stroke="currentColor" stroke-width="1.2" fill="none" />
    <circle cx="12" cy="38" r="2" stroke="currentColor" stroke-width="1.2" fill="none" />
    <circle cx="78" cy="38" r="2" stroke="currentColor" stroke-width="1.2" fill="none" />
  </svg>

  <!-- Squiggle mid-left -->
  <svg class="doodle d3" viewBox="0 0 120 20" fill="none">
    <path d="M2 10 q 10 -10 20 0 t 20 0 t 20 0 t 20 0 t 20 0 t 20 0"
      stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none" />
  </svg>

  <!-- Checkmark mid-right -->
  <svg class="doodle d4" viewBox="0 0 48 48" fill="none">
    <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="1.6" fill="none" stroke-dasharray="3 3" />
    <path d="M14 25 l7 8 l14 -16" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </svg>

  <!-- Heart bottom-left -->
  <svg class="doodle d5" viewBox="0 0 40 40" fill="none">
    <path d="M20 34 C 8 24, 2 16, 8 10 C 12 6, 18 8, 20 14 C 22 8, 28 6, 32 10 C 38 16, 32 24, 20 34 Z"
      stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round" />
  </svg>

  <!-- Dots cluster bottom-right -->
  <svg class="doodle d6" viewBox="0 0 60 60" fill="none">
    <circle cx="10" cy="10" r="2.5" fill="currentColor" />
    <circle cx="30" cy="6" r="2" fill="currentColor" />
    <circle cx="50" cy="14" r="2.8" fill="currentColor" />
    <circle cx="18" cy="30" r="2" fill="currentColor" />
    <circle cx="42" cy="34" r="2.4" fill="currentColor" />
    <circle cx="12" cy="52" r="2.2" fill="currentColor" />
    <circle cx="34" cy="54" r="2" fill="currentColor" />
  </svg>

  <!-- Loopy line top-center -->
  <svg class="doodle d7" viewBox="0 0 200 40" fill="none">
    <path d="M4 26 c 15 -30, 40 24, 60 12 s 45 -22, 68 -4 s 40 12, 62 -8"
      stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none" />
  </svg>

  <!-- Sparkle plus-sign bottom-center -->
  <svg class="doodle d8" viewBox="0 0 30 30" fill="none">
    <path d="M15 4 v22 M4 15 h22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
  </svg>

  <!-- Arrow squiggle bottom-left of copy area -->
  <svg class="doodle d9" viewBox="0 0 80 40" fill="none">
    <path d="M4 30 q 20 -30, 40 -10 t 30 -6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none" />
    <path d="M66 8 l 8 6 l -10 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </svg>
</div>

<style>
  .backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .doodle {
    position: absolute;
    display: block;
    opacity: 0.18;
  }

  /* Keep doodles only in true blank spaces — corners and edges, never behind text */
  .d1 { top: -8px;  left: -28px; width: 56px;  height: 56px; color: var(--blue); }
  .d2 { display: none; }
  .d3 { display: none; }
  .d4 { top: 50%;   right: -28px; width: 46px; height: 46px; color: var(--accent); opacity: 0.22; }
  .d5 { bottom: -18px; left: -22px; width: 36px; height: 36px; color: var(--plum); opacity: 0.2; }
  .d6 { bottom: -20px; right: -22px; width: 60px; height: 60px; color: var(--blue); opacity: 0.22; }
  .d7 { display: none; }
  .d8 { display: none; }
  .d9 { display: none; }

  @media (max-width: 720px) {
    .d1, .d4, .d5, .d6 { display: none; }
  }
</style>
