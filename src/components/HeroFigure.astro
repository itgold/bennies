---
---
<div class="figure" role="img" aria-label="Illustration of a person smiling, surrounded by labels showing programs Bennies helps with">
  <div class="figure-inner">
    <svg class="art" viewBox="0 0 400 460" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <!-- Layered warm backdrop -->
      <circle cx="200" cy="210" r="180" fill="#e6effb" />
      <circle cx="200" cy="210" r="152" fill="#fbeecb" />

      <!-- Ambient dots -->
      <circle cx="52" cy="90"  r="5" fill="#1e40af" />
      <circle cx="350" cy="70" r="7" fill="#0f6b3e" />
      <circle cx="360" cy="330" r="6" fill="#9a3412" />
      <circle cx="50" cy="330" r="9" fill="#a16207" />

      <!-- Sparkle marks -->
      <path d="M360 200 l3 -6 l3 6 l6 3 l-6 3 l-3 6 l-3 -6 l-6 -3 z" fill="#1e40af" />
      <path d="M40 220 l2 -5 l2 5 l5 2 l-5 2 l-2 5 l-2 -5 l-5 -2 z" fill="#0f6b3e" />

      <!-- Character group, well-proportioned bust -->
      <g transform="translate(200 210)">
        <!-- Shoulders / shirt (behind neck) -->
        <path
          d="M-125 200
             C -125 130, -95 100, -60 92
             L 60 92
             C 95 100, 125 130, 125 200
             Z"
          fill="#1e40af"
        />
        <!-- Shirt collar accent -->
        <path
          d="M-35 92 L 0 118 L 35 92"
          fill="#152d7a"
        />

        <!-- Neck -->
        <rect x="-18" y="60" width="36" height="42" rx="10" fill="#d9a37b" />

        <!-- Head -->
        <circle cx="0" cy="10" r="62" fill="#eab98d" />

        <!-- Hair — top -->
        <path
          d="M-62 6
             C -62 -60, -22 -78, 0 -78
             C 22 -78, 62 -60, 62 6
             C 58 -20, 40 -32, 20 -34
             C 0 -36, -20 -34, -40 -32
             C -50 -30, -58 -18, -62 6 Z"
          fill="#2a1c10"
        />
        <!-- Ear hint -->
        <ellipse cx="-60" cy="14" rx="6" ry="10" fill="#d9a37b" />
        <ellipse cx="60" cy="14" rx="6" ry="10" fill="#d9a37b" />

        <!-- Cheek blush (soft) -->
        <ellipse cx="-32" cy="26" rx="10" ry="6" fill="#f4a5a5" opacity="0.55" />
        <ellipse cx="32" cy="26" rx="10" ry="6" fill="#f4a5a5" opacity="0.55" />

        <!-- Eyes — closed-arc smiling eyes so proportions can't look off -->
        <path d="M-22 6 q 6 -6 12 0" stroke="#1a1a1a" stroke-width="3.5" fill="none" stroke-linecap="round" />
        <path d="M10 6 q 6 -6 12 0" stroke="#1a1a1a" stroke-width="3.5" fill="none" stroke-linecap="round" />

        <!-- Smile -->
        <path d="M-14 34 Q 0 46 14 34" stroke="#1a1a1a" stroke-width="3.5" fill="none" stroke-linecap="round" />
      </g>

      <!-- Leaf accent -->
      <g transform="translate(30 240)">
        <path d="M12 0 c-3 12 -10 20 -22 22 c6 14 12 20 22 34 c10 -14 16 -20 22 -34 c-12 -2 -19 -10 -22 -22 z" fill="#0f6b3e" />
      </g>
    </svg>

    <!-- Floating callouts -->
    <div class="callout callout-tl">
      <span class="callout-dot" style="background:#0f6b3e" aria-hidden="true"></span>
      <div class="callout-body">
        <span class="callout-label">Likely eligible</span>
        <span class="callout-name">SNAP · Food help</span>
      </div>
    </div>

    <div class="callout callout-tr">
      <span class="callout-dot" style="background:#a16207" aria-hidden="true"></span>
      <div class="callout-body">
        <span class="callout-label">Tax credit</span>
        <span class="callout-name">EITC · up to $7,830</span>
      </div>
    </div>

    <div class="callout callout-br">
      <span class="callout-dot" style="background:#1e40af" aria-hidden="true"></span>
      <div class="callout-body">
        <span class="callout-label">Health coverage</span>
        <span class="callout-name">Medicaid · Full coverage</span>
      </div>
    </div>
  </div>
</div>

<style>
  .figure {
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    position: relative;
    aspect-ratio: 400 / 460;
  }
  .figure-inner {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .art {
    display: block;
    width: 100%;
    height: 100%;
  }

  .callout {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--surface-white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 10px 14px;
    box-shadow: 0 10px 26px rgba(10, 10, 10, 0.09);
    max-width: 220px;
  }
  .callout-dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-pill);
    flex-shrink: 0;
  }
  .callout-body { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }
  .callout-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--ink-3);
    font-weight: 700;
    margin-bottom: 3px;
  }
  .callout-name {
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.005em;
  }

  .callout-tl { top: 10%; left: -4%; }
  .callout-tr { top: 26%; right: -6%; }
  .callout-br { bottom: 8%; right: 0; }

  @media (max-width: 900px) {
    .figure { max-width: 380px; }
    .callout-tl { left: 0; }
    .callout-tr { right: 0; }
    .callout-br { right: 4%; }
  }
  @media (max-width: 520px) {
    .callout { padding: 8px 10px; max-width: 180px; }
    .callout-label { font-size: 0.62rem; }
    .callout-name { font-size: 0.78rem; }
  }
</style>
