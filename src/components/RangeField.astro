---
interface Props {
  name: string;
  id: string;
  min: number;
  max: number;
  step: number;
  defaultValue: number;
  minLabel?: string;
  maxLabel?: string;
}
const { name, id, min, max, step, defaultValue, minLabel, maxLabel } = Astro.props;

const fmt = (n: number) =>
  n >= 1000 ? `$${(n / 1000).toFixed(0)}k` : `$${n}`;
---
<div class="range">
  <div class="range-topline">
    <span class="range-hint">Total (before taxes)</span>
    <output class="range-value" for={id} data-fmt="currency">
      {fmt(defaultValue)} – {fmt(defaultValue + 5000)}
    </output>
  </div>
  <input
    class="range-input"
    type="range"
    id={id}
    name={name}
    min={min}
    max={max}
    step={step}
    value={defaultValue}
    aria-valuemin={min}
    aria-valuemax={max}
    aria-valuenow={defaultValue}
  />
  <div class="range-scale" aria-hidden="true">
    <span>{minLabel ?? fmt(min)}</span>
    <span>{fmt(Math.round(max * 0.25))}</span>
    <span>{fmt(Math.round(max * 0.5))}</span>
    <span>{fmt(Math.round(max * 0.75))}</span>
    <span>{maxLabel ?? fmt(max)}</span>
  </div>
</div>

<style>
  .range { width: 100%; }
  .range-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--ink-3);
    margin-bottom: 8px;
  }
  .range-value {
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    font-weight: 700;
    color: var(--ink);
    font-size: 0.85rem;
  }
  .range-input {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--line);
    outline: none;
  }
  .range-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
    background: var(--color-blue);
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(37, 99, 235, 0.35);
    cursor: pointer;
  }
  .range-input::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
    background: var(--color-blue);
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(37, 99, 235, 0.35);
    cursor: pointer;
  }
  .range-input:focus-visible::-webkit-slider-thumb { outline: var(--focus-ring); outline-offset: 2px; }
  .range-scale {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    color: var(--ink-3);
    margin-top: 6px;
  }
</style>

<script>
  document.querySelectorAll<HTMLInputElement>('.range-input').forEach((input) => {
    const output = input.parentElement?.querySelector<HTMLOutputElement>('.range-value');
    if (!output) return;
    const fmt = (n: number) => (n >= 1000 ? `$${Math.round(n / 1000)}k` : `$${n}`);
    input.addEventListener('input', () => {
      const val = Number(input.value);
      const bandTop = Math.min(Number(input.max), val + Number(input.step) * 5);
      output.textContent = `${fmt(val)} – ${fmt(bandTop)}`;
      input.setAttribute('aria-valuenow', String(val));
    });
  });
</script>
