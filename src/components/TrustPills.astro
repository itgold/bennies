---
import { getCollection } from 'astro:content';
const pillars = await getCollection('trustPillars');
---
<section class="trust" aria-labelledby="trust-heading">
  <p class="trust-lead" id="trust-heading">
    <span aria-hidden="true">⚡</span> Built for impact. Powered by AI.
  </p>
  <ul class="trust-list">
    {pillars.map((p) => (
      <li class="trust-item">
        <span class="trust-icon" aria-hidden="true">{p.data.icon}</span>
        <span class="trust-body">
          <span class="trust-label">{p.data.label}</span>
          <span class="trust-desc">{p.data.description}</span>
        </span>
      </li>
    ))}
  </ul>
</section>

<style>
  .trust {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 20px;
    box-shadow: var(--shadow-sm);
  }
  .trust-lead {
    margin: 0 0 12px;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .trust-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .trust-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .trust-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .trust-body { display: flex; flex-direction: column; gap: 2px; }
  .trust-label { font-weight: 700; font-size: 0.85rem; color: var(--ink); }
  .trust-desc { font-size: 0.75rem; color: var(--ink-3); line-height: 1.35; }

  @media (max-width: 780px) {
    .trust-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 420px) {
    .trust-list { grid-template-columns: 1fr; }
  }
</style>
