---
import { getCollection } from 'astro:content';
const pillars = await getCollection('trustPillars');
const tones = ['green', 'blue', 'rust', 'plum'] as const;
---
<section class="trust" aria-labelledby="trust-heading">
  <p class="section-eyebrow eyebrow-blue" id="trust-heading">What matters to you, matters to us</p>
  <dl class="trust-list">
    {pillars.map((p, i) => {
      const tone = tones[i % tones.length];
      return (
        <div class={`trust-item tone-${tone}`}>
          <span class="trust-marker" aria-hidden="true"></span>
          <dt class="trust-label">{p.data.label}</dt>
          <dd class="trust-desc">{p.data.description}</dd>
        </div>
      );
    })}
  </dl>
</section>

<style>
  .trust {
    padding: 48px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .trust-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 20px 0 0;
    padding: 0;
  }
  .trust-item {
    padding: 4px 24px 4px 20px;
    border-right: 1px solid var(--line);
    margin-right: 24px;
    position: relative;
  }
  .trust-item:last-child { border-right: 0; margin-right: 0; }

  .trust-marker {
    position: absolute;
    left: 0;
    top: 8px;
    width: 4px;
    height: 24px;
    border-radius: var(--radius-pill);
  }
  .tone-green .trust-marker,
  .tone-blue .trust-marker,
  .tone-rust .trust-marker,
  .tone-plum .trust-marker { background: var(--blue); }

  .trust-label {
    font-weight: 700;
    color: var(--ink);
    font-size: 0.98rem;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .trust-desc {
    margin: 0;
    color: var(--ink-2);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .trust-list { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .trust-item { padding: 4px 0 4px 20px; border-right: 0; margin-right: 0; }
  }
  @media (max-width: 520px) {
    .trust-list { grid-template-columns: 1fr; }
  }
</style>
