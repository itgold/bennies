---
interface Props {
  size?: 'sm' | 'md';
  href?: string;
}
const { size = 'md', href = '/' } = Astro.props;
---
<a class={`logo logo-${size}`} href={href} aria-label="Bennies home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 20 20" width="100%" height="100%">
      <path
        d="M10 2c-1.4 3.4-4 5.4-7.5 6C4.5 12 7 15 10 19c3-4 5.5-7 7.5-11C14 7.4 11.4 5.4 10 2z"
        fill="#0f6b3e"
      />
    </svg>
  </span>
  <span class="logo-text">Bennies</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .logo:hover { color: var(--accent-strong); }
  .logo-mark {
    display: inline-flex;
    width: 22px;
    height: 22px;
  }
  .logo-md .logo-text { font-size: 1.25rem; }
  .logo-sm .logo-mark { width: 18px; height: 18px; }
  .logo-sm .logo-text { font-size: 1.05rem; }
</style>
