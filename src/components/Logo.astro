---
interface Props {
  size?: 'sm' | 'md';
  href?: string;
}
const { size = 'md', href = '/' } = Astro.props;
---
<a class={`logo logo-${size}`} href={href} aria-label="Bennies home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="100%" height="100%">
      <path
        d="M16 3c-2 5-6 8-11 9 3 6 7 10 11 17 4-7 8-11 11-17-5-1-9-4-11-9z"
        fill="#10b981"
      />
      <path d="M16 3v26" stroke="#059669" stroke-width="1.5" stroke-linecap="round" fill="none" />
    </svg>
  </span>
  <span class="logo-text">Bennies</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .logo:hover { color: var(--color-brand-strong); }
  .logo-mark {
    display: inline-flex;
    width: 30px;
    height: 30px;
  }
  .logo-md .logo-text { font-size: 1.5rem; }
  .logo-sm .logo-mark { width: 24px; height: 24px; }
  .logo-sm .logo-text { font-size: 1.2rem; }
</style>
